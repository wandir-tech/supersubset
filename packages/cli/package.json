{
  "name": "@supersubset/cli",
  "version": "0.1.0",
  "description": "Supersubset CLI — `npx supersubset import-schema` for Prisma/SQL/dbt/JSON metadata introspection",
  "license": "Apache-2.0",
  "author": "Wandir Technologies Inc.",
  "homepage": "https://github.com/wandir-tech/supersubset/tree/main/packages/cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wandir-tech/supersubset.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/wandir-tech/supersubset/issues"
  },
  "keywords": [
    "cli",
    "introspection",
    "analytics",
    "dashboard",
    "react",
    "supersubset"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "supersubset": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supersubset/data-model": "workspace:*",
    "@supersubset/schema": "workspace:*",
    "@supersubset/adapter-prisma": "workspace:*",
    "@supersubset/adapter-sql": "workspace:*",
    "@supersubset/adapter-json": "workspace:*",
    "@supersubset/adapter-dbt": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
