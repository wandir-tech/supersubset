{
  "name": "@supersubset/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "supersubset": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supersubset/data-model": "workspace:*",
    "@supersubset/schema": "workspace:*",
    "@supersubset/adapter-prisma": "workspace:*",
    "@supersubset/adapter-sql": "workspace:*",
    "@supersubset/adapter-json": "workspace:*",
    "@supersubset/adapter-dbt": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "license": "MIT"
}
