{
  "name": "@supersubset/designer",
  "version": "0.1.2",
  "description": "Supersubset designer: <SupersubsetDesigner /> drag-and-drop dashboard editor built on Puck",
  "license": "Apache-2.0",
  "author": "Wandir Technologies Inc.",
  "homepage": "https://github.com/wandir-tech/supersubset/tree/main/packages/designer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wandir-tech/supersubset.git",
    "directory": "packages/designer"
  },
  "bugs": {
    "url": "https://github.com/wandir-tech/supersubset/issues"
  },
  "keywords": [
    "drag-and-drop",
    "editor",
    "puck",
    "analytics",
    "dashboard",
    "react",
    "supersubset"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@puckeditor/core": "^0.21.2",
    "@supersubset/charts-echarts": "workspace:^",
    "@supersubset/data-model": "workspace:*",
    "@supersubset/runtime": "workspace:*",
    "@supersubset/schema": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
