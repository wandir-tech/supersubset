{
  "name": "@supersubset/adapter-prisma",
  "version": "0.1.1",
  "description": "Prisma schema to Supersubset normalized metadata adapter",
  "license": "Apache-2.0",
  "author": "Wandir Technologies Inc.",
  "homepage": "https://github.com/wandir-tech/supersubset/tree/main/packages/adapter-prisma#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wandir-tech/supersubset.git",
    "directory": "packages/adapter-prisma"
  },
  "bugs": {
    "url": "https://github.com/wandir-tech/supersubset/issues"
  },
  "keywords": [
    "prisma",
    "adapter",
    "introspection",
    "analytics",
    "dashboard",
    "react",
    "supersubset"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@supersubset/data-model": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
