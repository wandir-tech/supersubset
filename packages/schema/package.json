{
  "name": "@supersubset/schema",
  "version": "0.1.2",
  "description": "Canonical dashboard schema types, Zod validation, and JSON/YAML serializers for Supersubset",
  "license": "Apache-2.0",
  "author": "Wandir Technologies Inc.",
  "homepage": "https://github.com/wandir-tech/supersubset/tree/main/packages/schema#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wandir-tech/supersubset.git",
    "directory": "packages/schema"
  },
  "bugs": {
    "url": "https://github.com/wandir-tech/supersubset/issues"
  },
  "keywords": [
    "schema",
    "zod",
    "validation",
    "analytics",
    "dashboard",
    "react",
    "supersubset"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ test/"
  },
  "dependencies": {
    "yaml": "^2.8.3",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
