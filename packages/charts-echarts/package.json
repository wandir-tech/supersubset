{
  "name": "@supersubset/charts-echarts",
  "version": "0.1.1",
  "description": "ECharts-based widget pack for Supersubset (line, bar, pie, scatter, heatmap, sankey, KPI, and more)",
  "license": "Apache-2.0",
  "author": "Wandir Technologies Inc.",
  "homepage": "https://github.com/wandir-tech/supersubset/tree/main/packages/charts-echarts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wandir-tech/supersubset.git",
    "directory": "packages/charts-echarts"
  },
  "bugs": {
    "url": "https://github.com/wandir-tech/supersubset/issues"
  },
  "keywords": [
    "charts",
    "echarts",
    "visualization",
    "analytics",
    "dashboard",
    "react",
    "supersubset"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./essentials": {
      "types": "./dist/essentials.d.ts",
      "import": "./dist/essentials.js",
      "require": "./dist/essentials.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/essentials.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@supersubset/runtime": "workspace:*",
    "@supersubset/schema": "workspace:*",
    "@supersubset/theme": "workspace:*",
    "echarts": "^5.5.0"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
